BETTER PERFORMANCE - 
WITH MEDIAN_POS AS(
    SELECT ID, COMPANY, SALARY,ROW_NUMBER() OVER (PARTITION BY COMPANY ORDER BY SALARY, ID ASC) AS RN , COUNT(*) OVER (PARTITION BY COMPANY) AS TOTAL
    FROM EMPLOYEE
)

SELECT ID, COMPANY, SALARY
FROM MEDIAN_POS 
WHERE RN  BETWEEN (TOTAL)/2.0
AND (TOTAL+2)/2.0
