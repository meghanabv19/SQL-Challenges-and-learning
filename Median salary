/* Write your T-SQL query statement below */
WITH TOTAL_COUNT AS ( 
    SELECT COMPANY, COUNT(*) AS TOTAL
    FROM EMPLOYEE
    GROUP BY COMPANY
),

MEDIAN_COUNT AS ( 
    SELECT ID,COMPANY, SALARY,ROW_NUMBER() OVER (PARTITION BY COMPANY ORDER BY SALARY,ID ASC) AS RN 
    FROM EMPLOYEE 
)

SELECT ID , MDN.COMPANY, SALARY
FROM MEDIAN_COUNT MDN 
LEFT JOIN TOTAL_COUNT TTL 
ON (
    CASE WHEN TTL.TOTAL%2 =0 THEN 
    FLOOR((TTL.TOTAL)/2.00) ELSE CEILING((TTL.TOTAL+1)/2.00) END 
  )  = MDN.RN 
AND TTL.COMPANY = MDN.COMPANY
LEFT JOIN TOTAL_COUNT TTL1 
ON (
    CASE WHEN TTL1.TOTAL%2 =0 THEN 
CEILING((TTL1.TOTAL+1)/2.00) ELSE 0 END)= MDN.RN 
AND TTL1.COMPANY = MDN.COMPANY
WHERE TTL.COMPANY IS NOT NULL OR TTL1.COMPANY IS NOT NULL
 

