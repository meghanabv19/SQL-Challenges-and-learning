WITH RUNNING_FREQ AS(
    SELECT NUM, SUM(FREQUENCY) OVER (ORDER BY NUM) AS RUNNI_FREQ 
    FROM NUMBERS
),
MEDIAN_FREQ AS(
    SELECT CASE WHEN 
    SUM(FREQUENCY)%2 <> 0 THEN 
    SUM(FREQUENCY)/2.0 
    ELSE (SUM(FREQUENCY))/2.0  END AS MEDIAN_FREQ1, 
    CASE WHEN 
    SUM(FREQUENCY)%2 = 0 THEN 
    (SUM(FREQUENCY)+2)/2.0  END AS MEDIAN_FREQ2 
    FROM NUMBERS
),
MEDIAN_SUM AS(
SELECT  
CASE WHEN 
MEDIAN_FREQ1 BETWEEN
 ISNULL((LAG(RUNNI_FREQ) OVER (ORDER BY NUM)) ,0) AND RUNNI_FREQ 
THEN NUM END AS MEDIAN1,
CASE WHEN 
MEDIAN_FREQ2 BETWEEN
 ISNULL((LAG(RUNNI_FREQ) OVER (ORDER BY NUM)) ,0) AND RUNNI_FREQ 
THEN NUM END AS MEDIAN2
FROM RUNNING_FREQ
CROSS JOIN MEDIAN_FREQ
)

 
SELECT   
ROUND(SUM(MEDIAN1)/CAST(COUNT(*)AS FLOAT) ,1) 
  AS MEDIAN
FROM MEDIAN_SUM
WHERE MEDIAN1 IS NOT NULL
 
