BEST CASE - LAG FUNCTION


WITH THREE_CONSECUTIVE_NUM AS (
SELECT NUM , 
LAG(NUM,1) AS PREV1, 
LAG(NUM, 2) AS PREV2
FROM LOGS
)

SELECT DISTINCT NUM
FROM THREE_CONSECUTIVE_NUM
WHERE NUM=PRV1
AND PRV1=PRV2







 



